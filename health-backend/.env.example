# health-backend 환경설정 예시
# 실제 값을 채워 .env 파일로 복사하거나 GitHub Actions 변수/시크릿에 등록한다

# ---------- 서버 ----------
PORT=3000
NODE_ENV=development

# ---------- PostgreSQL ----------
DB_HOST=211.253.27.76
DB_PORT=5432
DB_NAME=db15
DB_USER=user15
DB_PASSWORD=

# ---------- JWT ----------
# 페이로드: userid, name, api_key
JWT_SECRET=
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=7d

# ---------- 건강정보 시뮬레이터 (외부) ----------
# 접속: {SIMULATOR_URL}?userId={member_id}&apiKey={api_key}
SIMULATOR_URL=wss://healthsim.iranglab.com/simulator

# ---------- health-ai (AI Agent) ----------
AI_API_URL=http://localhost:8000
AI_API_TIMEOUT_MS=30000

# ---------- Slack 알림 ----------
SLACK_WEBHOOK_URL=

# ---------- 로깅 (winston) ----------
LOG_DIR=./logs
LOG_LEVEL=debug
LOG_RETENTION_DAYS=7d

# ---------- 데이터 보존 ----------
DATA_RETENTION_DAYS=7
