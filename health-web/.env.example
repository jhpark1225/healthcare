# health-web 환경설정 예시
# .env.development 또는 .env.production 으로 복사해서 사용한다

# 개발 서버 포트
VITE_PORT=5173

# 백엔드 REST API URL
# 개발: http://127.0.0.1:3000
# 운영: GitHub Variables WEB_API_URL 값 사용 (예: https://fe015.ys.iranglab.com/api)
VITE_API_URL=http://127.0.0.1:3000

# 백엔드 WebSocket URL
# 개발: ws://127.0.0.1:3000
# 운영: GitHub Variables WEB_WS_URL 값 사용 (예: wss://fe015.ys.iranglab.com)
VITE_WS_URL=ws://127.0.0.1:3000
